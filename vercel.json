{
  "version": 2,
  "builds": [
    {
      "src": "api/attack.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/attack.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html" 
    } 
  ]
}
